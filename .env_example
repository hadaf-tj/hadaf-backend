# === DATABASE ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=shb

# === REDIS ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DEFAULT_DB=0
REDIS_TIMEOUT=5

# === MINIO ===
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=shb-files

# === GENERAL ===
APP_PORT=8000
APP_HOST=0.0.0.0
APP_ENV=local
LOG_LEVEL=debug

# === JWT ===
JWT_SECRET_KEY=
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# === OTP ===
OTP_LENGTH=6
OTP_TTL=5m
OTP_SEND_ATTEMPTS=3
OTP_SEND_BLOCK_TIME=300
OTP_MAX_ATTEMPTS=3
OTP_MAX_LOGIN_ATTEMPTS=5

# === SMS ===
SMS_API_KEY=mock_key
SMS_SENDER_NAME=Hadaf
SMS_LOGIN=login
SMS_BASE_URL=https://api.osonsms.com

# === SMTP ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@hadaf.tj
SMTP_FROM_NAME=Hadaf Platform

# === OBSERVABILITY (services in docker-compose.yml) ===
# Host ports for the monitoring stack and Grafana credentials. The application
# itself needs no extra config: it always exposes Prometheus metrics at /metrics.
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
LOKI_PORT=3100
TEMPO_PORT=3200
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# --- Tracing (Phase 3, OpenTelemetry) ---
# Disabled by default: the app installs a no-op tracer and emits no spans.
# Set OTEL_TRACES_ENABLED=true to push traces to the Collector.
OTEL_TRACES_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_NAME=shb
OTEL_SERVICE_VERSION=dev
# Head sampling probability in [0,1]; 1.0 traces everything (dev). Lower in prod.
OTEL_TRACES_SAMPLER_ARG=1.0