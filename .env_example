# Database (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=shb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO (Object Storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=shb-files

# App Service
APP_NAME=my-app
APP_PORT=8000
APP_HOST=localhost
APP_ENV=local
APP_WRITE_TIMEOUT=30
APP_READ_TIMEOUT=30

# Logging
LOG_LEVEL=debug
LOG_PATH=""
LOG_INCLUDE_CALLER=true


# SMS Service (Mock settings for now)
SMS_API_KEY=mock_key
SMS_SENDER_NAME=Payvand

# Security (JWT) - сгенерируйте случайную строку для продакшена, для дева пойдет эта
JWT_SECRET_KEY=super_secret_jwt_key_for_dev_only_change_in_prod
ACCESS_TOKEN_TTL=15m
ACCESS_TOKEN_SECRET=access_secret_jwt_key_for_dev_only_change_in_prod
REFRESH_TOKEN_TTL=720h
REFRESH_TOKEN_SECRET=refresh_secret_jwt_key_for_dev_only_change_in_prod

# OTP Settings
OTP_LENGTH=4
OTP_TTL=5m
OTP_SEND_ATTEMPTS=3
OTP_SEND_BLOCK_TIME=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3
OTP_MAX_LOGIN_ATTEMPTS=5
OTP_DURATION=5m